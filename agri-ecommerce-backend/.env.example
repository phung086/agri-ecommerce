DB_HOST=localhost
DB_PORT=3306
DB_NAME=veggie_main
DB_URL=jdbc:mysql://localhost:3306/veggie_main?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password

JWT_SECRET=AgriEcommerceJwtSecretKeyForLocalDevelopmentMustBeAtLeast32Chars2026
JWT_EXPIRATION_MS=86400000

APP_PUBLIC_BASE_URL=http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_sandbox_tmn_code
VNPAY_HASH_SECRET=your_sandbox_hash_secret
VNPAY_RETURN_URL=http://localhost:3000/checkout/vnpay-return
VNPAY_EXPIRE_MINUTES=15

# ===== AI Chatbot Configuration =====
# Bật/tắt tính năng AI chatbot (mặc định false để an toàn)
AI_CHATBOT_ENABLED=false

# Provider: "gemini" hoặc "openai"
AI_PROVIDER=gemini

# Tên model (gemini-1.5-flash, gemini-1.5-pro, gpt-4o-mini, gpt-4o, ...)
AI_MODEL=gemini-2.5-flash

# API Keys — điền key thật vào đây, KHÔNG commit file .env thật
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Số sản phẩm tối đa đưa vào prompt context
AI_MAX_PRODUCTS_CONTEXT=10

# Timeout gọi LLM tính bằng giây
AI_TIMEOUT_SECONDS=20
