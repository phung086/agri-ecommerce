{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "cd agri-ecommerce-backend && sh mvnw -DskipTests package"
  },
  "deploy": {
    "startCommand": "java -jar agri-ecommerce-backend/target/agri-ecommerce-backend-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
